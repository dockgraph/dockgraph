# Deny-by-default: only allow files needed for the Docker build.
*

# Backend
!backend/**/*.go
backend/**/*_test.go
!backend/go.mod
!backend/go.sum

# Frontend
!frontend/src/
frontend/src/**/*.test.*
!frontend/public/
!frontend/index.html
!frontend/package.json
!frontend/package-lock.json
!frontend/tsconfig*.json
!frontend/vite.config.ts
